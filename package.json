{
  "name": "@y-tinypool/monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write '**/*.{ts,js,mjs}'",
    "release": "bumpp package.json packages/*/package.json --commit --push --tag",
    "test:ci": "turbo run test:ci",
    "typecheck": "turbo run typecheck",
    "preversion": "turbo run test:ci"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "bumpp": "latest",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=v20.10.0"
  }
}
