{
  "name": "y-tinypool",
  "version": "0.0.1",
  "description": "Execute Y.js in tinypool",
  "keywords": [
    "yjs",
    "tinypool",
    "worker_threads"
  ],
  "homepage": "https://github.com/yjl9903/y-tinypool#readme",
  "bugs": {
    "url": "https://github.com/yjl9903/y-tinypool/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yjl9903/y-tinypool.git"
  },
  "license": "MIT",
  "author": "XLor",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest",
    "test:ci": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tinypool": "^2.1.0",
    "yjs": "^13.6.29"
  },
  "engines": {
    "node": ">=v20.10.0"
  }
}
